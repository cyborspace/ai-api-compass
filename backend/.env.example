# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ai_api_compass?schema=public"

# Redis (Upstash)
REDIS_URL="rediss://default:password@host.upstash.io:6379"

# Meilisearch
MEILISEARCH_URL="https://xxx.meilisearch.io"
MEILISEARCH_API_KEY="your-api-key"

# App Config
NODE_ENV="development"
PORT=8000
SECRET_KEY="your-secret-key-change-in-production"
CORS_ORIGINS="http://localhost:3000,https://your-app.vercel.app"

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

# Heat Scheduler Configuration
HEAT_UPDATE_INTERVAL=300000      # 热度更新间隔 (毫秒), 默认 5 分钟
HEAT_SCHEDULER_AUTO_START=true   # 是否自动启动热度调度器
HEAT_RUN_ON_START=false          # 启动时是否立即执行一次热度计算
