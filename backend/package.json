{
  "name": "ai-api-compass-backend",
  "version": "1.0.0",
  "description": "AI API Compass - Backend API",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc --noEmitOnError false || tsc --noEmitOnError false --incremental false",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx src/seed/aigc.seed.ts",
    "db:seed:clear": "tsx -e \"import { PrismaClient } from '@prisma/client'; const p = new PrismaClient(); async function clear() { const types=['AIGCTool','ToolCategory']; for(const apiName of types){ const ot=await p.objectType.findUnique({where:{apiName}}); if(!ot)continue; const objs=await p.object.findMany({where:{objectTypeId:ot.id},select:{id:true}}); const ids=objs.map(o=>o.id); if(ids.length>0){ await p.link.deleteMany({where:{OR:[{sourceObjectId:{in:ids}},{targetObjectId:{in:ids}}]}}); await p.object.deleteMany({where:{objectTypeId:ot.id}}); } console.log('Cleared '+ids.length+' '+apiName); } await p.\\$disconnect(); } clear().catch(console.error);\"",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.0",
    "@fastify/rate-limit": "^9.0.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^4.0.0",
    "@prisma/adapter-pg": "^6.19.3",
    "@prisma/client": "^6.19.3",
    "axios": "^1.16.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.4.0",
    "fastify": "^4.28.0",
    "fastify-plugin": "^4.5.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.3",
    "meilisearch": "^0.41.0",
    "pg": "^8.20.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@esbuild/darwin-arm64": "^0.28.0",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^1.6.0",
    "prisma": "^6.19.3",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
